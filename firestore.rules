rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function docData(path) { return get(/databases/$(database)/documents/ + path).data; }
    
    function isSuperAdmin() { 
      return isSignedIn() && docData('users/' + request.auth.uid).username == 'RafaelGtz'; 
    }
    
    function isAdmin() { 
      return isSignedIn() && docData('users/' + request.auth.uid).role == 'admin'; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.username is string && data.username.size() <= 40
        && data.role in ['admin', 'user']
        && data.status in ['pending', 'active', 'rejected'];
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      
      // Allow registration or admin creation
      allow create: if isSignedIn() && isValidUser(request.resource.data);
      
      allow update: if isSuperAdmin() && isValidUser(request.resource.data) && (
        // Prevent editing Super Admin by others (redundant but safe)
        docData('users/' + userId).username != 'RafaelGtz' || request.auth.uid == userId
      );
      
      allow delete: if isSuperAdmin() && docData('users/' + userId).username != 'RafaelGtz';
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
